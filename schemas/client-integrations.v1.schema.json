{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lloom.dev/schemas/client-integrations.v1.schema.json",
  "title": "LLooM Client Integrations v1",
  "description": "Portable discovery document for clients that want to connect to a LLooM-compatible local gateway.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "id", "name", "provider", "models"],
  "properties": {
    "$schema": {
      "const": "https://lloom.dev/schemas/client-integrations.v1.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "profile": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/profile"
    },
    "id": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "license": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/license"
    },
    "publisher": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/publisher"
    },
    "createdAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "provenance": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/provenance"
    },
    "links": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/links"
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "clients": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/client"
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/model"
      }
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "$defs": {
    "provider": {
      "type": "object",
      "required": ["id", "name", "baseUrl", "defaultModel"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "baseUrl": {
          "type": "string",
          "minLength": 1,
          "description": "OpenAI-compatible base URL. Kept as the historical short name for openAIBaseUrl."
        },
        "gatewayUrl": {
          "type": "string",
          "minLength": 1,
          "description": "Gateway origin without protocol-specific path suffixes. Anthropic-compatible SDKs commonly append /v1/messages to this origin."
        },
        "openAIBaseUrl": {
          "type": "string",
          "minLength": 1,
          "description": "OpenAI-compatible base URL, normally ending in /v1."
        },
        "anthropicBaseUrl": {
          "type": "string",
          "minLength": 1,
          "description": "Anthropic-compatible gateway origin. Clients should append /v1/messages unless their client contract asks for a fully qualified endpoint."
        },
        "apiKey": {
          "type": "string",
          "description": "Local development token or placeholder. Public catalogs should prefer auth.apiKeyEnv."
        },
        "auth": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["none", "bearer", "api-key", "env"]
            },
            "header": {
              "type": "string"
            },
            "apiKeyEnv": {
              "type": "string"
            }
          }
        },
        "protocols": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["openai-chat-completions", "openai-responses", "anthropic-messages"]
          },
          "uniqueItems": true
        },
        "features": {
          "type": "object",
          "additionalProperties": true,
          "description": "Gateway-level protocol capabilities clients can rely on before inspecting individual models.",
          "properties": {
            "streaming": {
              "type": "boolean"
            },
            "usage": {
              "type": "boolean"
            },
            "streamingUsage": {
              "type": "boolean",
              "description": "Usage accounting is available in or at the end of streamed responses."
            },
            "tools": {
              "type": "boolean"
            },
            "reasoning": {
              "type": "boolean"
            }
          }
        },
        "endpoints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "models": {
              "type": "string"
            },
            "chatCompletions": {
              "type": "string"
            },
            "responses": {
              "type": "string"
            },
            "anthropicMessages": {
              "type": "string"
            },
            "images": {
              "type": "string"
            },
            "embeddings": {
              "type": "string"
            },
            "speech": {
              "type": "string"
            },
            "transcriptions": {
              "type": "string"
            }
          }
        },
        "defaultModel": {
          "type": "string",
          "minLength": 1
        }
      },
      "patternProperties": {
        "^x-": true
      }
    },
    "client": {
      "type": "object",
      "required": ["id", "name", "kind"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": ["native-config", "env-profile", "launcher", "discovery"]
        },
        "protocols": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/artifact"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "patternProperties": {
        "^x-": true
      }
    },
    "artifact": {
      "type": "object",
      "required": ["id", "kind"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "targetPath": {
          "type": ["string", "null"]
        },
        "generatedPath": {
          "type": "string"
        },
        "executable": {
          "type": "boolean"
        }
      }
    },
    "model": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "output": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "capabilities": {
          "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/capabilities"
        },
        "supportsTools": {
          "type": "boolean"
        },
        "reasoning": {
          "type": "boolean"
        },
        "contextWindow": {
          "type": "integer",
          "minimum": 0
        },
        "maxOutputTokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "patternProperties": {
        "^x-": true
      }
    }
  }
}
