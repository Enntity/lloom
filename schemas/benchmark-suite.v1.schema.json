{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lloom.dev/schemas/benchmark-suite.v1.schema.json",
  "title": "LLooM Benchmark Suite v1",
  "description": "Portable benchmark evidence for local model/backend recipes.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "id", "name", "submittedAt", "results"],
  "properties": {
    "$schema": {
      "const": "https://lloom.dev/schemas/benchmark-suite.v1.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "profile": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/profile"
    },
    "id": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "license": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/license"
    },
    "publisher": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/publisher"
    },
    "source": {
      "oneOf": [
        {
          "type": "string"
        },
        {
          "type": "object",
          "additionalProperties": true
        }
      ]
    },
    "submittedAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "createdAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "provenance": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/provenance"
    },
    "links": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/links"
    },
    "methodology": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "harness": {
          "type": "string"
        },
        "harnessVersion": {
          "type": "string"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "promptCorpus": {
          "type": "string"
        },
        "warmupRuns": {
          "type": "integer",
          "minimum": 0
        },
        "measurementRuns": {
          "type": "integer",
          "minimum": 1
        },
        "streaming": {
          "type": "boolean"
        }
      }
    },
    "results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/result"
      }
    }
  },
  "patternProperties": {
    "^x-": true
  },
  "$defs": {
    "result": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "recipeId", "backendId", "model", "machine", "metrics"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "recipeId": {
          "type": "string",
          "minLength": 1
        },
        "recipeVersion": {
          "type": "integer",
          "minimum": 1
        },
        "backendId": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "gatewayModel": {
          "type": "string"
        },
        "machine": {
          "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/machine"
        },
        "settings": {
          "type": "object",
          "additionalProperties": true
        },
        "workload": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": {
              "type": "string"
            },
            "promptTokens": {
              "type": "integer",
              "minimum": 0
            },
            "outputTokens": {
              "type": "integer",
              "minimum": 0
            },
            "contextDepth": {
              "type": "integer",
              "minimum": 0
            },
            "concurrency": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": true,
          "anyOf": [
            {
              "required": ["generationTokPerSec"]
            },
            {
              "required": ["prefillTokPerSec"]
            },
            {
              "required": ["generationSeconds"]
            },
            {
              "required": ["imagesPerMinute"]
            }
          ],
          "properties": {
            "generationTokPerSec": {
              "type": "number",
              "minimum": 0
            },
            "prefillTokPerSec": {
              "type": "number",
              "minimum": 0
            },
            "contextWindow": {
              "type": "integer",
              "minimum": 1
            },
            "timeToFirstTokenMs": {
              "type": "number",
              "minimum": 0
            },
            "outputThroughputTokPerSec": {
              "type": "number",
              "minimum": 0
            },
            "totalTokPerSec": {
              "type": "number",
              "minimum": 0
            },
            "peakMemoryGb": {
              "type": "number",
              "minimum": 0
            },
            "generationSeconds": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "imagesPerMinute": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "patternProperties": {
        "^x-": true
      }
    }
  }
}
