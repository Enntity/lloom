{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lloom.dev/schemas/recipe-pack.v1.schema.json",
  "title": "LLooM Recipe Pack v1",
  "description": "Bundle format for publishing LLooM recipes, index metadata, benchmark evidence, and optional detached trust material.",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "id", "name", "recipes"],
  "properties": {
    "$schema": {
      "const": "https://lloom.dev/schemas/recipe-pack.v1.schema.json"
    },
    "schemaVersion": {
      "const": 1
    },
    "profile": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/profile"
    },
    "id": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string"
    },
    "license": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/license"
    },
    "updatedAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "createdAt": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/dateTime"
    },
    "publisher": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/publisher"
    },
    "provenance": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/provenance"
    },
    "links": {
      "$ref": "https://lloom.dev/schemas/common.v1.schema.json#/$defs/links"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "id"],
        "additionalProperties": true,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["backend", "model", "recipe", "schema", "tool"]
          },
          "id": {
            "type": "string",
            "minLength": 1
          },
          "version": {
            "type": "string"
          },
          "optional": {
            "type": "boolean"
          }
        }
      }
    },
    "signatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["keyId", "algorithm", "signature"],
        "additionalProperties": true,
        "properties": {
          "keyId": {
            "type": "string",
            "minLength": 1
          },
          "algorithm": {
            "const": "ed25519"
          },
          "canonicalization": {
            "const": "lloom-canonical-json-v1"
          },
          "publicKey": {
            "type": "string"
          },
          "signature": {
            "type": "string",
            "contentEncoding": "base64"
          }
        }
      }
    },
    "recipes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["index", "recipe"],
        "additionalProperties": true,
        "properties": {
          "index": {
            "$ref": "https://lloom.dev/schemas/recipe-index.v1.schema.json#/properties/recipes/items"
          },
          "recipe": {
            "$ref": "https://lloom.dev/schemas/recipe.v1.schema.json"
          },
          "benchmarks": {
            "type": "array",
            "items": {
              "$ref": "https://lloom.dev/schemas/benchmark-suite.v1.schema.json"
            }
          }
        },
        "patternProperties": {
          "^x-": true
        }
      }
    }
  },
  "patternProperties": {
    "^x-": true
  }
}
