{
  "name": "LLooM",
  "server": {
    "host": "127.0.0.1",
    "port": 8100
  },
  "ports": {
    "gateway": 8100,
    "backends": {
      "start": 8201,
      "end": 8299
    }
  },
  "security": {
    "allowMissingAuth": true,
    "allowRemoteAdmin": false,
    "allowWildcardCors": false,
    "allowNonLoopbackBind": false,
    "apiKeys": [
      "sk-lloom-local"
    ],
    "adminApiKeys": []
  },
  "logging": {
    "requestLog": false,
    "requestLogPath": null
  },
  "runtimePolicy": {
    "enabled": true,
    "autoEvict": false,
    "reserveMemoryGb": 12,
    "protectActiveRequests": true,
    "protectKeepWarm": false
  },
  "community": {
    "hostUrl": "http://127.0.0.1:8110",
    "recipeFeedPath": "/v1/recipe-packs/recommended",
    "signingKeysPath": "/v1/keys",
    "trustHostKeys": false,
    "leaderboardPath": "/v1/leaderboard",
    "submissionPath": "/v1/benchmarks",
    "recipePackSubmissionPath": "/v1/recipe-packs",
    "requireSignedPacks": true,
    "autoStartLocalHost": true,
    "localHostStartupTimeoutMs": 5000,
    "workloads": [
      "agentic-coding"
    ],
    "capabilities": [
      "tools",
      "reasoning",
      "long-context"
    ],
    "tags": [],
    "trustedKeys": []
  },
  "communityHost": {
    "mode": "development",
    "indexPath": "community/recipes/index.json",
    "recipesRoot": "community/recipes",
    "benchmarksRoot": "community/benchmarks",
    "backendCatalogPath": "backends/catalog.json",
    "publisher": "lloom-dev-host",
    "keyId": "lloom-dev-seed",
    "privateKeyPath": "community/keys/lloom-dev-signing-private.pem",
    "publicKeyPath": "community/keys/lloom-dev-signing-public.pem"
  },
  "defaults": {
    "chatModel": "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
    "imageModel": "black-forest-labs/FLUX.1-schnell",
    "speechModel": "mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit",
    "transcriptionModel": "mlx-community/whisper-large-v3-turbo-asr-fp16"
  },
  "providers": {
    "local-llm": {
      "name": "LLooM Local",
      "baseUrl": "http://127.0.0.1:8100/v1",
      "apiKey": "sk-lloom-local"
    }
  },
  "backends": {
    "mtplx-27b": {
      "type": "openai",
      "baseUrl": "http://127.0.0.1:8201/v1",
      "apiKey": "sk-local-llm",
      "timeoutMs": 1800000
    },
    "mtplx-35b-a3b": {
      "type": "openai",
      "baseUrl": "http://127.0.0.1:8202/v1",
      "apiKey": "sk-local-llm",
      "timeoutMs": 1800000
    },
    "flux-schnell": {
      "type": "openai",
      "baseUrl": "http://127.0.0.1:8210/v1",
      "apiKey": "sk-local-llm",
      "timeoutMs": 1800000
    },
    "mlx-audio": {
      "type": "openai",
      "baseUrl": "http://127.0.0.1:8220/v1",
      "apiKey": "sk-local-llm",
      "timeoutMs": 1800000
    }
  },
  "models": [
    {
      "id": "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "name": "Qwen3.6 27B MTPLX Speed",
      "backend": "mtplx-27b",
      "runtime": "mtplx-qwen36-27b-speed",
      "upstreamModel": "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "kind": "chat",
      "input": [
        "text",
        "image"
      ],
      "output": [
        "text"
      ],
      "capabilities": [
        "chat",
        "tools",
        "reasoning",
        "long-context",
        "mtp"
      ],
      "reasoning": true,
      "supportsTools": true,
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "advertise": true,
      "tags": [
        "apple-silicon",
        "qwen3.6",
        "dense",
        "fastest-27b"
      ]
    },
    {
      "id": "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
      "name": "Qwen3.6 35B-A3B MTPLX Speed FP16",
      "backend": "mtplx-35b-a3b",
      "runtime": "mtplx-qwen36-35b-a3b-speed-fp16",
      "upstreamModel": "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
      "kind": "chat",
      "input": [
        "text",
        "image"
      ],
      "output": [
        "text"
      ],
      "capabilities": [
        "chat",
        "tools",
        "reasoning",
        "long-context",
        "mtp",
        "moe"
      ],
      "reasoning": true,
      "supportsTools": true,
      "contextWindow": 262144,
      "maxOutputTokens": 32768,
      "advertise": true,
      "tags": [
        "apple-silicon",
        "qwen3.6",
        "moe",
        "fastest-35b"
      ],
      "maxPromptTokens": 120000
    },
    {
      "id": "black-forest-labs/FLUX.1-schnell",
      "name": "FLUX.1 Schnell",
      "backend": "flux-schnell",
      "runtime": "flux-schnell",
      "upstreamModel": "black-forest-labs/FLUX.1-schnell",
      "kind": "image",
      "input": [
        "text"
      ],
      "output": [
        "image"
      ],
      "capabilities": [
        "image-generation"
      ],
      "contextWindow": 4096,
      "maxOutputTokens": 0,
      "advertise": true,
      "tags": [
        "image",
        "flux",
        "fast"
      ]
    },
    {
      "id": "mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit",
      "name": "Qwen3 TTS 0.6B Custom Voice 4bit",
      "backend": "mlx-audio",
      "runtime": "mlx-audio",
      "upstreamModel": "mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit",
      "kind": "audio_speech",
      "input": [
        "text"
      ],
      "output": [
        "audio"
      ],
      "capabilities": [
        "audio-speech",
        "tts",
        "tts-custom-voice",
        "tts-style-instruct",
        "qwen3-tts"
      ],
      "tts": {
        "family": "qwen3-tts",
        "mode": "custom_voice"
      },
      "contextWindow": 4096,
      "maxOutputTokens": 4096,
      "advertise": true,
      "tags": [
        "audio",
        "tts",
        "qwen3",
        "custom-voice"
      ]
    },
    {
      "id": "mlx-community/Qwen3-TTS-12Hz-1.7B-VoiceDesign-4bit",
      "name": "Qwen3 TTS 1.7B Voice Design 4bit",
      "backend": "mlx-audio",
      "runtime": "mlx-audio",
      "upstreamModel": "mlx-community/Qwen3-TTS-12Hz-1.7B-VoiceDesign-4bit",
      "kind": "audio_speech",
      "input": [
        "text"
      ],
      "output": [
        "audio"
      ],
      "capabilities": [
        "audio-speech",
        "tts",
        "tts-voice-design",
        "qwen3-tts"
      ],
      "tts": {
        "family": "qwen3-tts",
        "mode": "voice_design"
      },
      "contextWindow": 4096,
      "maxOutputTokens": 4096,
      "advertise": true,
      "tags": [
        "audio",
        "tts",
        "qwen3",
        "voice-design"
      ]
    },
    {
      "id": "mlx-community/Qwen3-TTS-12Hz-0.6B-Base-4bit",
      "name": "Qwen3 TTS 0.6B Base (voice clone) 4bit",
      "backend": "mlx-audio",
      "runtime": "mlx-audio",
      "upstreamModel": "mlx-community/Qwen3-TTS-12Hz-0.6B-Base-4bit",
      "kind": "audio_speech",
      "input": [
        "text"
      ],
      "output": [
        "audio"
      ],
      "capabilities": [
        "audio-speech",
        "tts",
        "tts-voice-clone",
        "qwen3-tts"
      ],
      "tts": {
        "family": "qwen3-tts",
        "mode": "voice_clone"
      },
      "contextWindow": 4096,
      "maxOutputTokens": 4096,
      "advertise": true,
      "tags": [
        "audio",
        "tts",
        "qwen3",
        "voice-clone"
      ]
    },
    {
      "id": "mlx-community/whisper-large-v3-turbo-asr-fp16",
      "name": "Whisper Large v3 Turbo ASR fp16",
      "backend": "mlx-audio",
      "runtime": "mlx-audio",
      "upstreamModel": "mlx-community/whisper-large-v3-turbo-asr-fp16",
      "kind": "audio_transcription",
      "input": [
        "audio"
      ],
      "output": [
        "text"
      ],
      "capabilities": [
        "audio-transcription",
        "stt"
      ],
      "stt": {
        "family": "whisper"
      },
      "contextWindow": 4096,
      "maxOutputTokens": 4096,
      "advertise": true,
      "tags": [
        "audio",
        "stt",
        "whisper"
      ]
    }
  ],
  "aliases": {
    "qwen36-27b-fastest": {
      "target": "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "advertise": true,
      "description": "Fastest observed dense Qwen3.6 27B route on Apple Silicon."
    },
    "qwen36-dense-fastest": {
      "target": "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "advertise": true,
      "description": "Dense Qwen3.6 fast lane."
    },
    "qwen36-35b-fastest": {
      "target": "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
      "advertise": true,
      "description": "Fastest observed Qwen3.6 35B-A3B route on Apple Silicon."
    },
    "qwen36-moe-fastest": {
      "target": "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
      "advertise": true,
      "description": "MoE Qwen3.6 fast lane."
    },
    "flux-schnell": {
      "target": "black-forest-labs/FLUX.1-schnell",
      "advertise": true,
      "description": "Default local image-generation route."
    },
    "qwen3-tts": {
      "target": "mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit",
      "advertise": true,
      "description": "Default local TTS (CustomVoice presets)."
    },
    "qwen3-tts-custom": {
      "target": "mlx-community/Qwen3-TTS-12Hz-0.6B-CustomVoice-4bit",
      "advertise": true,
      "description": "Qwen3-TTS CustomVoice — built-in speakers + style instructions."
    },
    "qwen3-tts-design": {
      "target": "mlx-community/Qwen3-TTS-12Hz-1.7B-VoiceDesign-4bit",
      "advertise": true,
      "description": "Qwen3-TTS VoiceDesign — describe a voice in natural language."
    },
    "qwen3-tts-clone": {
      "target": "mlx-community/Qwen3-TTS-12Hz-0.6B-Base-4bit",
      "advertise": true,
      "description": "Qwen3-TTS Base — zero-shot clone from ref_audio + ref_text."
    },
    "whisper-stt": {
      "target": "mlx-community/whisper-large-v3-turbo-asr-fp16",
      "advertise": true,
      "description": "Default local speech-to-text route."
    }
  },
  "runtimes": {
    "mtplx-qwen36-27b-speed": {
      "enabled": false,
      "command": "mtplx",
      "args": [
        "serve",
        "--model",
        "${LLOOM_MTPLX_MODEL_ROOT}/Youssofal--Qwen3.6-27B-MTPLX-Optimized-Speed",
        "--host",
        "127.0.0.1",
        "--port",
        "8201",
        "--model-id",
        "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
        "--profile",
        "turbo",
        "--depth",
        "3",
        "--context-window",
        "262144",
        "--max-tokens",
        "32768",
        "--reasoning",
        "auto",
        "--preserve-thinking",
        "auto",
        "--batching-preset",
        "agent",
        "--max-active-requests",
        "1",
        "--paged-kv-quantization",
        "q8",
        "--no-stats-footer"
      ],
      "sessionCache": {
        "kind": "mtplx-ssd-session",
        "mode": "on",
        "dir": "${LLOOM_SESSION_CACHE_ROOT}/mtplx-qwen36-27b-speed",
        "maxSize": "100GB",
        "minPrefixTokens": 512
      },
      "port": 8201,
      "healthUrl": "http://127.0.0.1:8201/health",
      "startupTimeoutMs": 900000,
      "memoryGb": 32,
      "maxConcurrency": 1,
      "policy": {
        "priority": 100,
        "evictable": true
      },
      "warmup": {
        "url": "http://127.0.0.1:8201/v1/chat/completions",
        "method": "POST",
        "body": {
          "model": "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
          "messages": [
            {
              "role": "user",
              "content": "Reply with OK."
            }
          ],
          "max_tokens": 2,
          "stream": false
        }
      }
    },
    "mtplx-qwen36-35b-a3b-speed-fp16": {
      "keepWarm": true,
      "enabled": false,
      "command": "mtplx",
      "args": [
        "serve",
        "--model",
        "${LLOOM_MTPLX_MODEL_ROOT}/Youssofal--Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
        "--host",
        "127.0.0.1",
        "--port",
        "8202",
        "--model-id",
        "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
        "--profile",
        "sustained",
        "--depth",
        "1",
        "--context-window",
        "262144",
        "--max-tokens",
        "32768",
        "--reasoning",
        "auto",
        "--preserve-thinking",
        "auto",
        "--batching-preset",
        "agent",
        "--max-active-requests",
        "1",
        "--paged-kv-quantization",
        "q8",
        "--no-stats-footer"
      ],
      "sessionCache": {
        "kind": "mtplx-ssd-session",
        "mode": "on",
        "dir": "${LLOOM_SESSION_CACHE_ROOT}/mtplx-qwen36-35b-a3b-speed-fp16",
        "maxSize": "100GB",
        "minPrefixTokens": 512
      },
      "port": 8202,
      "healthUrl": "http://127.0.0.1:8202/health",
      "startupTimeoutMs": 900000,
      "memoryGb": 72,
      "maxConcurrency": 1,
      "policy": {
        "priority": 80,
        "evictable": true
      },
      "warmup": {
        "url": "http://127.0.0.1:8202/v1/chat/completions",
        "method": "POST",
        "body": {
          "model": "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
          "messages": [
            {
              "role": "user",
              "content": "Reply with OK."
            }
          ],
          "max_tokens": 2,
          "stream": false
        }
      }
    },
    "flux-schnell": {
      "enabled": false,
      "command": "python",
      "args": [
        "-m",
        "lloom_flux_server"
      ],
      "port": 8210,
      "healthUrl": "http://127.0.0.1:8210/health",
      "startupTimeoutMs": 900000,
      "memoryGb": 12,
      "policy": {
        "priority": 20,
        "evictable": true
      },
      "maxConcurrency": 1
    },
    "mlx-audio": {
      "enabled": false,
      "command": "lloom-audio-server",
      "args": [
        "--host",
        "127.0.0.1",
        "--port",
        "8220"
      ],
      "port": 8220,
      "healthUrl": "http://127.0.0.1:8220/health",
      "startupTimeoutMs": 900000,
      "memoryGb": 6,
      "policy": {
        "priority": 40,
        "evictable": true
      },
      "maxConcurrency": 1
    }
  },
  "clientCatalog": {
    "providerId": "local-llm",
    "providerName": "LLooM Local",
    "modelOrder": [
      "Youssofal/Qwen3.6-35B-A3B-MTPLX-Optimized-Speed-FP16",
      "Youssofal/Qwen3.6-27B-MTPLX-Optimized-Speed",
      "qwen36-35b-fastest",
      "qwen36-27b-fastest",
      "black-forest-labs/FLUX.1-schnell"
    ]
  }
}
