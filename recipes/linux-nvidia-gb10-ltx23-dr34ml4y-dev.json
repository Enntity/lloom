{
  "$schema": "https://lloom.dev/schemas/recipe.v1.schema.json",
  "schemaVersion": 1,
  "profile": "https://lloom.dev/profiles/interchange/v1",
  "id": "linux-nvidia-gb10-ltx23-dr34ml4y-dev",
  "name": "DGX Spark LTX-2.3 Dev + DR34ML4Y Quality",
  "version": 1,
  "summary": "Author-recommended LTX-2.3 dev two-stage generation with DR34ML4Y V3 and partial distillation.",
  "license": { "id": "LicenseRef-LTX-2-Community", "name": "LTX-2 Community License plus LoRA terms" },
  "provenance": {
    "createdBy": "lloom",
    "generatedBy": "manual-curated",
    "source": "Official Lightricks LTX-2.3 two-stage pipeline plus locally supplied DR34ML4Y V3 LoRA"
  },
  "links": [
    { "rel": "model", "href": "https://huggingface.co/Lightricks/LTX-2.3", "mediaType": "text/html" },
    { "rel": "runtime", "href": "https://github.com/Lightricks/LTX-2", "mediaType": "text/html" }
  ],
  "keywords": ["linux", "nvidia", "dgx-spark", "gb10", "ltx-2.3", "dev", "video-generation", "lora", "dr34ml4y"],
  "capabilities": ["video-generation", "text-to-video", "audio-video", "lora", "cfg", "two-stage"],
  "hardware": {
    "family": "NVIDIA GB10 / DGX Spark",
    "testedMachine": "DGX Spark with 128 GB unified memory",
    "notes": [
      "The quality runtime is cold/on-demand and mutually exclusive with other large runtimes.",
      "FP8 cast is enabled to preserve unified-memory headroom for CFG, decoding, and Gemma."
    ]
  },
  "requirements": {
    "platforms": ["linux-arm64"],
    "memoryGb": 100,
    "diskGb": 170,
    "commands": ["docker", "hf"],
    "accelerators": ["cuda", "nvidia-gpu", "blackwell", "gb10"]
  },
  "backend": {
    "id": "docker-ltx-video",
    "name": "Docker LTX Video for NVIDIA GB10",
    "type": "openai-videos-server",
    "features": ["cuda", "blackwell", "video-generation", "text-to-video", "audio-video", "lora", "cfg", "two-stage"]
  },
  "setup": {
    "steps": [
      {
        "id": "check-dev-checkpoint",
        "title": "Verify the supplied LTX-2.3 dev checkpoint",
        "action": "command",
        "command": "python3",
        "args": ["-c", "import os,sys; sys.exit(0 if os.path.getsize(sys.argv[1]) == 46149344974 else 1)", "${modelRoot}/ltx-2.3-dr34ml4y/ltx-2.3-22b-dev.safetensors"]
      },
      {
        "id": "check-dr34ml4y-lora",
        "title": "Verify the supplied DR34ML4Y V3 LoRA",
        "action": "command",
        "command": "test",
        "args": ["-f", "${modelRoot}/ltx-2.3-dr34ml4y/DR34ML4Y_LT3X_V3.safetensors"]
      },
      {
        "id": "download-distillation-lora",
        "title": "Download the official LTX-2.3 distillation LoRA",
        "action": "command",
        "command": "${modelRoot}/../bin/hf",
        "args": ["download", "Lightricks/LTX-2.3", "ltx-2.3-22b-distilled-lora-384-1.1.safetensors", "--local-dir", "${modelRoot}/ltx-2.3-dr34ml4y"],
        "skipIfPathExists": "${modelRoot}/ltx-2.3-dr34ml4y/ltx-2.3-22b-distilled-lora-384-1.1.safetensors"
      },
      {
        "id": "download-spatial-upscaler",
        "title": "Download the official LTX-2.3 spatial upscaler",
        "action": "command",
        "command": "${modelRoot}/../bin/hf",
        "args": ["download", "Lightricks/LTX-2.3", "ltx-2.3-spatial-upscaler-x2-1.1.safetensors", "--local-dir", "${modelRoot}/ltx-2.3-dr34ml4y"],
        "skipIfPathExists": "${modelRoot}/ltx-2.3-dr34ml4y/ltx-2.3-spatial-upscaler-x2-1.1.safetensors"
      },
      {
        "id": "download-gemma-encoder",
        "title": "Download the official Gemma 3 12B QAT text encoder",
        "action": "command",
        "command": "${modelRoot}/../bin/hf",
        "args": ["download", "Lightricks/gemma-3-12b-it-qat-q4_0-unquantized", "--local-dir", "${modelRoot}/ltx-2.3-dr34ml4y/gemma-3-12b"],
        "skipIfPathExists": "${modelRoot}/ltx-2.3-dr34ml4y/gemma-3-12b/config.json"
      }
    ]
  },
  "models": [
    {
      "role": "quality-video",
      "model": "Lightricks/LTX-2.3-DR34ML4Y-Dev",
      "gatewayModel": "Lightricks/LTX-2.3-DR34ML4Y-Dev",
      "name": "LTX-2.3 Dev + DR34ML4Y V3 · Quality",
      "runtime": "ltx23-dr34ml4y-dev",
      "backendConfig": "ltx23-dr34ml4y-dev",
      "backend": "LTX-2.3 CUDA",
      "input": ["text", "image"],
      "output": ["video", "audio"],
      "capabilities": ["video-generation", "text-to-video", "image-to-video", "audio-video", "lora", "cfg", "two-stage"],
      "settings": {
        "maxActiveRequests": 1,
        "memoryGb": 100,
        "priority": 36,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 1800000,
        "timeoutMs": 7200000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "ltx23-dr34ml4y-dev",
          "healthUrl": "http://127.0.0.1:${port}/health",
          "bootstrap": {
            "adapter": "docker",
            "image": "lloom/ltx-video:2.3",
            "pull": false,
            "createArgs": [
              "--restart", "unless-stopped", "--gpus", "all", "--ipc", "host",
              "-p", "127.0.0.1:${port}:8000",
              "-v", "${modelRoot}/ltx-2.3-dr34ml4y:/models:ro",
              "-e", "LTX_MODEL_ID=Lightricks/LTX-2.3-DR34ML4Y-Dev",
              "-e", "LTX_PIPELINE=two-stage",
              "-e", "LTX_CHECKPOINT=/models/ltx-2.3-22b-dev.safetensors",
              "-e", "LTX_DISTILLED_LORA=/models/ltx-2.3-22b-distilled-lora-384-1.1.safetensors",
              "-e", "LTX_DISTILLED_LORA_STRENGTH=0.30",
              "-e", "LTX_NUM_INFERENCE_STEPS=30",
              "-e", "LTX_VIDEO_CFG_GUIDANCE_SCALE=3.0"
            ],
            "command": []
          }
        }
      }
    }
  ]
}
