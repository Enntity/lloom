{
  "$schema": "https://lloom.dev/schemas/recipe.v1.schema.json",
  "schemaVersion": 1,
  "profile": "https://lloom.dev/profiles/interchange/v1",
  "id": "linux-nvidia-gb10-image-generation",
  "name": "DGX Spark FLUX.2 Klein 4B + Qwen Image",
  "version": 1,
  "summary": "LLooM-managed Docker lanes for fast Apache-2.0 FLUX.2 Klein 4B generation/editing, Qwen-Image-2512 generation, and Qwen-Image-Edit-2511 reference editing on NVIDIA GB10.",
  "license": { "id": "Apache-2.0", "name": "Model and recipe license" },
  "provenance": {
    "createdBy": "lloom",
    "generatedBy": "manual-curated",
    "source": "Official Black Forest Labs and Qwen checkpoints served by stable-diffusion.cpp"
  },
  "links": [
    { "rel": "model", "href": "https://huggingface.co/black-forest-labs/FLUX.2-klein-4B", "mediaType": "text/html" },
    { "rel": "model", "href": "https://huggingface.co/Qwen/Qwen-Image-2512", "mediaType": "text/html" },
    { "rel": "model", "href": "https://huggingface.co/Qwen/Qwen-Image-Edit-2511", "mediaType": "text/html" },
    { "rel": "runtime", "href": "https://github.com/leejet/stable-diffusion.cpp", "mediaType": "text/html" }
  ],
  "keywords": [
    "linux",
    "nvidia",
    "dgx-spark",
    "gb10",
    "image-generation",
    "image-editing",
    "flux2",
    "qwen-image",
    "docker"
  ],
  "capabilities": ["image-generation", "image-editing"],
  "hardware": {
    "family": "NVIDIA GB10 / DGX Spark",
    "testedMachine": "DGX Spark with 128 GB unified memory",
    "notes": [
      "All lanes are cold/on-demand and LLooM admission may evict other large runtimes before generation.",
      "FLUX.2 Klein 4B is the four-step interactive default and supports one or more reference images.",
      "Qwen-Image-2512 is the quality text-to-image lane; Qwen-Image-Edit-2511 is the reference-faithful edit lane.",
      "Qwen-Image-Edit-2511 requires qwen_image_zero_cond_t=true; omitting it substantially degrades edit quality."
    ]
  },
  "requirements": {
    "platforms": ["linux-arm64"],
    "memoryGb": 96,
    "diskGb": 96,
    "commands": ["docker", "hf"],
    "accelerators": ["cuda", "nvidia-gpu", "blackwell", "gb10"]
  },
  "backend": {
    "id": "docker-stable-diffusion-cpp",
    "name": "stable-diffusion.cpp CUDA container",
    "type": "openai-images-server",
    "features": ["cuda", "blackwell", "openai-images", "image-generation", "image-editing", "flux2", "qwen-image"]
  },
  "setup": {
    "steps": [
      {
        "id": "download-flux2-klein-4b-diffusion",
        "title": "Download FLUX.2 Klein 4B Q8 diffusion weights",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "leejet/FLUX.2-klein-4B-GGUF",
          "flux-2-klein-4b-Q8_0.gguf",
          "--revision",
          "3b1f5a9dc3abb32238b053aeb3d823c30afdacbd",
          "--local-dir",
          "${modelRoot}/lloom-flux2-klein-4b"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-flux2-klein-4b/flux-2-klein-4b-Q8_0.gguf"
      },
      {
        "id": "download-flux2-klein-4b-components",
        "title": "Download FLUX.2 Klein VAE and Qwen3 text encoder",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "Comfy-Org/vae-text-encorder-for-flux-klein-4b",
          "split_files/text_encoders/qwen_3_4b.safetensors",
          "split_files/vae/flux2-vae.safetensors",
          "--revision",
          "a9e4ca87c16db4c4e1a16406a9ddb300ab0ae246",
          "--local-dir",
          "${modelRoot}/lloom-flux2-klein-4b"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-flux2-klein-4b/split_files/vae/flux2-vae.safetensors"
      },
      {
        "id": "download-qwen-image-2512-diffusion",
        "title": "Download Qwen-Image-2512 Q8 diffusion weights",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "unsloth/Qwen-Image-2512-GGUF",
          "qwen-image-2512-Q8_0.gguf",
          "--revision",
          "1626d7531f84b4d2ea1cd6d2e69f41ec027dd354",
          "--local-dir",
          "${modelRoot}/lloom-qwen-image-2512"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-qwen-image-2512/qwen-image-2512-Q8_0.gguf"
      },
      {
        "id": "download-qwen-image-shared-components",
        "title": "Download the shared Qwen-Image VAE and Qwen2.5-VL text encoder",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "Comfy-Org/Qwen-Image_ComfyUI",
          "split_files/text_encoders/qwen_2.5_vl_7b.safetensors",
          "split_files/vae/qwen_image_vae.safetensors",
          "--revision",
          "46839d338df81ce625d5fae27d7e370314c0fbc9",
          "--local-dir",
          "${modelRoot}/lloom-qwen-image-shared"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-qwen-image-shared/split_files/text_encoders/qwen_2.5_vl_7b.safetensors"
      },
      {
        "id": "download-qwen-image-edit-2511-diffusion",
        "title": "Download Qwen-Image-Edit-2511 Q8 diffusion weights",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "unsloth/Qwen-Image-Edit-2511-GGUF",
          "qwen-image-edit-2511-Q8_0.gguf",
          "--revision",
          "0d33d9692b4b26212297240d87b0d4719aa4fd06",
          "--local-dir",
          "${modelRoot}/lloom-qwen-image-edit-2511"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-qwen-image-edit-2511/qwen-image-edit-2511-Q8_0.gguf"
      }
    ]
  },
  "models": [
    {
      "role": "default-image",
      "model": "black-forest-labs/FLUX.2-klein-4B",
      "gatewayModel": "black-forest-labs/FLUX.2-klein-4B",
      "name": "FLUX.2 Klein 4B Q8",
      "setDefault": true,
      "runtime": "flux2-klein-4b-sdcpp",
      "backendConfig": "flux2-klein-4b-sdcpp",
      "backend": "stable-diffusion.cpp CUDA",
      "input": ["text", "image"],
      "output": ["image"],
      "capabilities": ["image-generation", "image-editing"],
      "settings": {
        "maxActiveRequests": 1,
        "memoryGb": 24,
        "priority": 70,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 900000,
        "timeoutMs": 1800000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "flux2-klein-4b-sdcpp",
          "healthUrl": "http://127.0.0.1:${port}/v1/models",
          "warmup": false,
          "bootstrap": {
            "adapter": "docker",
            "image": "lloom/stable-diffusion.cpp:flux2-cuda",
            "pull": false,
            "createArgs": [
              "--restart", "unless-stopped", "--gpus", "all", "--ipc", "host",
              "-p", "127.0.0.1:${port}:8000",
              "--entrypoint", "/sd-server",
              "-v", "${modelRoot}:/models:ro"
            ],
            "command": [
              "--listen-ip", "0.0.0.0", "--listen-port", "8000",
              "--diffusion-model", "/models/lloom-flux2-klein-4b/flux-2-klein-4b-Q8_0.gguf",
              "--llm", "/models/lloom-flux2-klein-4b/split_files/text_encoders/qwen_3_4b.safetensors",
              "--vae", "/models/lloom-flux2-klein-4b/split_files/vae/flux2-vae.safetensors",
              "--cfg-scale", "1.0", "--steps", "4", "--sampling-method", "euler", "--diffusion-fa"
            ]
          }
        }
      }
    },
    {
      "role": "quality-image",
      "model": "Qwen/Qwen-Image-2512",
      "gatewayModel": "Qwen/Qwen-Image-2512",
      "name": "Qwen-Image-2512 Q8",
      "runtime": "qwen-image-2512-sdcpp",
      "backendConfig": "qwen-image-2512-sdcpp",
      "backend": "stable-diffusion.cpp CUDA",
      "input": ["text"],
      "output": ["image"],
      "capabilities": ["image-generation"],
      "settings": {
        "maxActiveRequests": 1,
      "memoryGb": 44,
        "priority": 65,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 1200000,
        "timeoutMs": 1800000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "qwen-image-2512-sdcpp",
          "healthUrl": "http://127.0.0.1:${port}/v1/models",
          "warmup": false,
          "bootstrap": {
            "adapter": "docker",
            "image": "lloom/stable-diffusion.cpp:flux2-cuda",
            "pull": false,
            "createArgs": [
              "--restart", "unless-stopped", "--gpus", "all", "--ipc", "host",
              "-p", "127.0.0.1:${port}:8000",
              "--entrypoint", "/sd-server",
              "-v", "${modelRoot}:/models:ro"
            ],
            "command": [
              "--listen-ip", "0.0.0.0", "--listen-port", "8000",
              "--diffusion-model", "/models/lloom-qwen-image-2512/qwen-image-2512-Q8_0.gguf",
              "--llm", "/models/lloom-qwen-image-shared/split_files/text_encoders/qwen_2.5_vl_7b.safetensors",
              "--vae", "/models/lloom-qwen-image-shared/split_files/vae/qwen_image_vae.safetensors",
              "--cfg-scale", "4.0", "--steps", "20", "--sampling-method", "euler", "--flow-shift", "3", "--diffusion-fa"
            ]
          }
        }
      }
    },
    {
      "role": "quality-image-edit",
      "model": "Qwen/Qwen-Image-Edit-2511",
      "gatewayModel": "Qwen/Qwen-Image-Edit-2511",
      "name": "Qwen-Image-Edit-2511 Q8",
      "runtime": "qwen-image-edit-2511-sdcpp",
      "backendConfig": "qwen-image-edit-2511-sdcpp",
      "backend": "stable-diffusion.cpp CUDA",
      "input": ["text", "image"],
      "output": ["image"],
      "capabilities": ["image-editing"],
      "settings": {
        "maxActiveRequests": 1,
      "memoryGb": 44,
        "priority": 66,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 1200000,
        "timeoutMs": 1800000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "qwen-image-edit-2511-sdcpp",
          "healthUrl": "http://127.0.0.1:${port}/v1/models",
          "warmup": false,
          "bootstrap": {
            "adapter": "docker",
            "image": "lloom/stable-diffusion.cpp:flux2-cuda",
            "pull": false,
            "createArgs": [
              "--restart", "unless-stopped", "--gpus", "all", "--ipc", "host",
              "-p", "127.0.0.1:${port}:8000",
              "--entrypoint", "/sd-server",
              "-v", "${modelRoot}:/models:ro"
            ],
            "command": [
              "--listen-ip", "0.0.0.0", "--listen-port", "8000",
              "--diffusion-model", "/models/lloom-qwen-image-edit-2511/qwen-image-edit-2511-Q8_0.gguf",
              "--llm", "/models/lloom-qwen-image-shared/split_files/text_encoders/qwen_2.5_vl_7b.safetensors",
              "--vae", "/models/lloom-qwen-image-shared/split_files/vae/qwen_image_vae.safetensors",
              "--cfg-scale", "2.5", "--steps", "20", "--sampling-method", "euler", "--flow-shift", "3",
              "--model-args", "qwen_image_zero_cond_t=true", "--diffusion-fa"
            ]
          }
        }
      }
    }
  ]
}
