{
  "$schema": "https://lloom.dev/schemas/recipe.v1.schema.json",
  "schemaVersion": 1,
  "profile": "https://lloom.dev/profiles/interchange/v1",
  "id": "linux-nvidia-gb10-ltx23-dr34ml4y",
  "name": "DGX Spark LTX-2.3 Distilled + DR34ML4Y",
  "version": 1,
  "summary": "On-demand LTX-2.3 distilled audio/video generation on NVIDIA GB10 with the DR34ML4Y V3 LoRA.",
  "license": { "id": "LicenseRef-LTX-2-Community", "name": "LTX-2 Community License plus LoRA terms" },
  "provenance": {
    "createdBy": "lloom",
    "generatedBy": "manual-curated",
    "source": "Official Lightricks LTX-2.3 pipeline and locally supplied DR34ML4Y V3 LoRA"
  },
  "links": [
    { "rel": "model", "href": "https://huggingface.co/Lightricks/LTX-2.3", "mediaType": "text/html" },
    { "rel": "runtime", "href": "https://github.com/Lightricks/LTX-2", "mediaType": "text/html" }
  ],
  "keywords": ["linux", "nvidia", "dgx-spark", "gb10", "ltx-2.3", "video-generation", "text-to-video", "lora", "dr34ml4y"],
  "capabilities": ["video-generation", "text-to-video", "audio-video", "lora"],
  "hardware": {
    "family": "NVIDIA GB10 / DGX Spark",
    "testedMachine": "DGX Spark with 128 GB unified memory",
    "notes": [
      "The runtime is cold/on-demand and LLooM should evict other large runtimes before admission.",
      "FP8 cast is enabled by default to leave unified-memory headroom for decoding and the Gemma encoder."
    ]
  },
  "requirements": {
    "platforms": ["linux-arm64"],
    "memoryGb": 96,
    "diskGb": 120,
    "commands": ["docker", "hf"],
    "accelerators": ["cuda", "nvidia-gpu", "blackwell", "gb10"]
  },
  "backend": {
    "id": "docker-ltx-video",
    "name": "Docker LTX Video for NVIDIA GB10",
    "type": "openai-videos-server",
    "features": ["cuda", "blackwell", "video-generation", "text-to-video", "audio-video", "lora"]
  },
  "setup": {
    "steps": [
      {
        "id": "check-distilled-checkpoint",
        "title": "Verify the supplied LTX-2.3 distilled checkpoint",
        "action": "command",
        "command": "test",
        "args": ["-f", "${modelRoot}/ltx-2.3-dr34ml4y/ltx-2.3-22b-distilled-1.1.safetensors"]
      },
      {
        "id": "check-dr34ml4y-lora",
        "title": "Verify the supplied DR34ML4Y V3 LoRA",
        "action": "command",
        "command": "test",
        "args": ["-f", "${modelRoot}/ltx-2.3-dr34ml4y/DR34ML4Y_LT3X_V3.safetensors"]
      },
      {
        "id": "download-spatial-upscaler",
        "title": "Download the official LTX-2.3 spatial upscaler",
        "action": "command",
        "command": "${modelRoot}/../bin/hf",
        "args": ["download", "Lightricks/LTX-2.3", "ltx-2.3-spatial-upscaler-x2-1.1.safetensors", "--local-dir", "${modelRoot}/ltx-2.3-dr34ml4y"],
        "skipIfPathExists": "${modelRoot}/ltx-2.3-dr34ml4y/ltx-2.3-spatial-upscaler-x2-1.1.safetensors"
      },
      {
        "id": "download-gemma-encoder",
        "title": "Download the official Gemma 3 12B QAT text encoder",
        "action": "command",
        "command": "${modelRoot}/../bin/hf",
        "args": ["download", "Lightricks/gemma-3-12b-it-qat-q4_0-unquantized", "--local-dir", "${modelRoot}/ltx-2.3-dr34ml4y/gemma-3-12b"],
        "skipIfPathExists": "${modelRoot}/ltx-2.3-dr34ml4y/gemma-3-12b/config.json"
      }
    ]
  },
  "models": [
    {
      "role": "default-video",
      "model": "Lightricks/LTX-2.3-DR34ML4Y",
      "gatewayModel": "Lightricks/LTX-2.3-DR34ML4Y",
      "name": "LTX-2.3 Distilled 1.1 + DR34ML4Y V3",
      "runtime": "ltx23-dr34ml4y",
      "backendConfig": "ltx23-dr34ml4y",
      "backend": "LTX-2.3 CUDA",
      "input": ["text", "image"],
      "output": ["video", "audio"],
      "capabilities": ["video-generation", "text-to-video", "image-to-video", "audio-video", "lora"],
      "settings": {
        "maxActiveRequests": 1,
        "memoryGb": 96,
        "priority": 35,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 1800000,
        "timeoutMs": 3600000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "ltx23-dr34ml4y",
          "healthUrl": "http://127.0.0.1:${port}/health",
          "bootstrap": {
            "adapter": "docker",
            "image": "lloom/ltx-video:2.3",
            "pull": false,
            "createArgs": [
              "--restart", "unless-stopped", "--gpus", "all", "--ipc", "host",
              "-p", "127.0.0.1:${port}:8000",
              "-v", "${modelRoot}/ltx-2.3-dr34ml4y:/models:ro"
            ],
            "command": []
          }
        }
      }
    }
  ]
}
