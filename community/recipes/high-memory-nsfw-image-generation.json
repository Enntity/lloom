{
  "$schema": "https://lloom.dev/schemas/recipe.v1.schema.json",
  "schemaVersion": 1,
  "profile": "https://lloom.dev/profiles/interchange/v1",
  "id": "high-memory-nsfw-image-generation",
  "name": "High-memory NSFW image generation",
  "version": 1,
  "summary": "Host-catalog opt-in image lanes for CyberRealistic Pony v18 and the Aisha V96 FLUX.2 Klein 9B NSFW merge.",
  "license": { "id": "LicenseRef-Mixed", "name": "Model-specific licenses; review upstream terms before use" },
  "provenance": {
    "createdBy": "lloom",
    "generatedBy": "manual-curated",
    "source": "Upstream Hugging Face model cards and LLooM DGX Spark validation"
  },
  "links": [
    { "rel": "model", "href": "https://huggingface.co/cyberdelia/CyberRealisticPony", "mediaType": "text/html" },
    {
      "rel": "model",
      "href": "https://huggingface.co/xPhoenix777/Flux-Klein-9b-GGUF-Conversions-NSFW",
      "mediaType": "text/html"
    }
  ],
  "keywords": ["image-generation", "nsfw", "sdxl", "pony", "flux2", "stable-diffusion-cpp", "host-only"],
  "capabilities": ["image-generation"],
  "hardware": {
    "family": "High-memory Apple Silicon and NVIDIA CUDA",
    "testedMachine": "DGX Spark / GB10 128 GB",
    "notes": [
      "These adult-content-capable community models are intentionally host-only and are never included in LLooM's bundled default catalog.",
      "Users are responsible for upstream licenses, applicable law, consent, and safe-use requirements."
    ]
  },
  "requirements": {
    "platforms": ["darwin-arm64", "linux-arm64", "linux-x64"],
    "memoryGb": 32,
    "diskGb": 50,
    "commands": ["hf", "sd-server"],
    "accelerators": ["apple-gpu", "cuda", "nvidia-gpu"]
  },
  "backend": {
    "id": "stable-diffusion-cpp",
    "name": "stable-diffusion.cpp",
    "type": "openai-images-server",
    "features": ["metal", "cuda", "openai-images", "flux2", "sdxl"]
  },
  "setup": {
    "steps": [
      {
        "id": "download-cyberrealistic-pony-v18",
        "title": "Download CyberRealistic Pony v18 FP16",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "cyberdelia/CyberRealisticPony",
          "CyberRealisticPony_V18.0_F16.safetensors",
          "--local-dir",
          "${modelRoot}/lloom-cyberrealistic-pony-v18"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-cyberrealistic-pony-v18/CyberRealisticPony_V18.0_F16.safetensors"
      },
      {
        "id": "download-aisha-flux2-klein-9b",
        "title": "Download Aisha V96 FLUX.2 Klein 9B Q5",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "xPhoenix777/Flux-Klein-9b-GGUF-Conversions-NSFW",
          "aishaNSFWFlux2Klein_betaV96Preview-Q5_K_M.gguf",
          "--local-dir",
          "${modelRoot}/lloom-aisha-flux2-klein-9b"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-aisha-flux2-klein-9b/aishaNSFWFlux2Klein_betaV96Preview-Q5_K_M.gguf"
      },
      {
        "id": "download-flux2-klein-9b-components",
        "title": "Download FLUX.2 Klein 9B VAE and text encoder",
        "action": "command",
        "command": "hf",
        "args": [
          "download",
          "Comfy-Org/vae-text-encorder-for-flux-klein-9b",
          "split_files/text_encoders/qwen_3_8b.safetensors",
          "split_files/vae/flux2-vae.safetensors",
          "--local-dir",
          "${modelRoot}/lloom-aisha-flux2-klein-9b"
        ],
        "skipIfPathExists": "${modelRoot}/lloom-aisha-flux2-klein-9b/split_files/vae/flux2-vae.safetensors"
      }
    ]
  },
  "models": [
    {
      "role": "sdxl-nsfw",
      "model": "cyberdelia/CyberRealisticPony-v18",
      "gatewayModel": "cyberdelia/CyberRealisticPony-v18",
      "runtime": "cyberrealistic-pony-v18-sdcpp",
      "backendConfig": "cyberrealistic-pony-v18-sdcpp",
      "backend": "stable-diffusion.cpp Metal/CUDA",
      "input": ["text"],
      "output": ["image"],
      "capabilities": ["image-generation"],
      "settings": {
        "maxActiveRequests": 1,
        "memoryGb": 14,
        "priority": 45,
        "evictable": true,
        "keepWarm": false,
        "runtime": {
          "command": "sd-server",
          "args": [
            "--listen-ip",
            "127.0.0.1",
            "--listen-port",
            "${port}",
            "--model",
            "${modelRoot}/lloom-cyberrealistic-pony-v18/CyberRealisticPony_V18.0_F16.safetensors",
            "--cfg-scale",
            "5",
            "--steps",
            "30",
            "--clip-skip",
            "2",
            "--sampling-method",
            "dpm++2m",
            "--scheduler",
            "karras",
            "--diffusion-fa"
          ],
          "baseUrlPath": "/v1",
          "healthPath": "/health",
          "warmup": false
        }
      }
    },
    {
      "role": "flux2-nsfw",
      "model": "xPhoenix777/Flux-Klein-9b-NSFW-Aisha-V96-Q5",
      "gatewayModel": "xPhoenix777/Flux-Klein-9b-NSFW-Aisha-V96-Q5",
      "runtime": "aisha-flux2-klein-9b-sdcpp",
      "backendConfig": "aisha-flux2-klein-9b-sdcpp",
      "backend": "stable-diffusion.cpp Metal/CUDA",
      "input": ["text"],
      "output": ["image"],
      "capabilities": ["image-generation"],
      "settings": {
        "maxActiveRequests": 1,
        "memoryGb": 32,
        "priority": 40,
        "evictable": true,
        "keepWarm": false,
        "runtime": {
          "command": "sd-server",
          "args": [
            "--listen-ip",
            "127.0.0.1",
            "--listen-port",
            "${port}",
            "--diffusion-model",
            "${modelRoot}/lloom-aisha-flux2-klein-9b/aishaNSFWFlux2Klein_betaV96Preview-Q5_K_M.gguf",
            "--llm",
            "${modelRoot}/lloom-aisha-flux2-klein-9b/split_files/text_encoders/qwen_3_8b.safetensors",
            "--vae",
            "${modelRoot}/lloom-aisha-flux2-klein-9b/split_files/vae/flux2-vae.safetensors",
            "--cfg-scale",
            "1.0",
            "--steps",
            "4",
            "--sampling-method",
            "euler",
            "--diffusion-fa"
          ],
          "baseUrlPath": "/v1",
          "healthPath": "/health",
          "warmup": false
        }
      }
    }
  ]
}
