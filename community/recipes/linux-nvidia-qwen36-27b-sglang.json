      {
        "id": "download-qwen36-27b",
        "title": "Download Qwen3.6 27B (prefer NVFP4/FP8 weights on Spark)",
        "action": "download-model",
        "provider": "huggingface",
        "model": "Qwen/Qwen3.6-27B"
      }
    ]
  },
  "models": [
    {
      "role": "default",
      "model": "Qwen/Qwen3.6-27B",
      "gatewayModel": "Qwen/Qwen3.6-27B",
      "runtime": "sglang-qwen36-27b",
      "backendConfig": "sglang-qwen36-27b",
      "backend": "SGLang CUDA",
      "input": ["text"],
      "output": ["text"],
      "capabilities": [
        "chat",
        "responses",
        "anthropic-messages",
        "streaming",
        "usage",
        "tools",
        "reasoning",
        "batching",
        "long-context"
      ],
      "settings": {
        "contextWindow": 131072,
        "maxOutputTokens": 32768,
        "maxActiveRequests": 4,
        "memoryGb": 96,
        "runtime": {
          "command": "sglang-python",
          "args": [
            "-m",
            "sglang.launch_server",
            "--model-path",
            "${modelPath}",
            "--host",
            "127.0.0.1",
            "--port",
            "${port}",
            "--served-model-name",
            "${modelId}",
            "--tp",
            "1",
            "--context-length",
            "131072",
            "--mem-fraction-static",
            "0.85",
            "--trust-remote-code",
            "--enable-metrics"
          ],
          "adapter": "sglang",
          "baseUrlPath": "/v1",
          "healthPath": "/health",
          "warmupPath": "/v1/chat/completions"
        }
      },
      "observed": {
        "notes": "Seed SGLang lane for agentic prefix reuse on Spark-class hardware. Override tool/reasoning parsers per SGLang version."
