        "contextWindow": 262144,
        "maxOutputTokens": 32768,
        "maxActiveRequests": 10,
        "sessionCache": true,
        "runtime": {
          "command": "mtplx",
          "args": [
            "serve",
            "--model",
            "${modelPath}",
            "--host",
            "127.0.0.1",
            "--port",
            "${port}",
            "--model-id",
            "${modelId}",
            "--profile",
            "turbo",
            "--depth",
            "3",
            "--context-window",
            "262144",
            "--max-tokens",
            "32768",
            "--reasoning",
            "auto",
            "--preserve-thinking",
