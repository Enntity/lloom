{
  "$schema": "https://lloom.dev/schemas/recipe.v1.schema.json",
  "schemaVersion": 1,
  "profile": "https://lloom.dev/profiles/interchange/v1",
  "id": "linux-nvidia-gb10-qwen36-unsloth-vllm",
  "name": "DGX Spark Qwen3.6 Unsloth NVFP4 vLLM",
  "version": 2,
  "summary": "The curated Qwen3.6 27B dense and 35B-A3B MoE NVFP4 lanes for 128 GB NVIDIA GB10 systems; the dense lane defaults to released vLLM 0.25.",
  "license": { "id": "Apache-2.0", "name": "Qwen model license" },
  "provenance": {
    "createdBy": "lloom",
    "generatedBy": "manual-curated",
    "source": "Unsloth model cards, vLLM documentation, and LLooM DGX Spark validation"
  },
  "links": [
    { "rel": "model", "href": "https://huggingface.co/unsloth/Qwen3.6-27B-NVFP4", "mediaType": "text/html" },
    { "rel": "model", "href": "https://huggingface.co/unsloth/Qwen3.6-35B-A3B-NVFP4", "mediaType": "text/html" }
  ],
  "keywords": ["linux", "nvidia", "dgx-spark", "gb10", "qwen3.6", "unsloth", "nvfp4", "vllm"],
  "capabilities": [
    "chat",
    "responses",
    "anthropic-messages",
    "streaming",
    "usage",
    "tools",
    "reasoning",
    "mtp",
    "batching",
    "long-context"
  ],
  "hardware": {
    "family": "NVIDIA GB10 / DGX Spark",
    "testedMachine": "DGX Spark with 128 GB unified memory",
    "notes": [
      "The 35B-A3B MoE lane is the fast general default; the 27B dense lane is the quality-oriented alternative.",
      "Both are on-demand and sized so LLooM can admit one large chat runtime at a time alongside a small embedding runtime."
    ]
  },
  "requirements": {
    "platforms": ["linux-arm64"],
    "memoryGb": 96,
    "diskGb": 80,
    "commands": ["docker"],
    "accelerators": ["cuda", "nvidia-gpu", "blackwell", "gb10"]
  },
  "backend": {
    "id": "docker-vllm",
    "name": "Docker vLLM for NVIDIA GB10",
    "type": "openai-compatible-server",
    "features": ["cuda", "blackwell", "openai-chat", "streaming", "tools", "batching", "mtp"]
  },
  "setup": {
    "steps": [
      {
        "id": "check-docker",
        "title": "Check Docker",
        "action": "check-command",
        "command": "docker",
        "args": ["--version"]
      }
    ]
  },
  "models": [
    {
      "role": "default",
      "model": "unsloth/Qwen3.6-35B-A3B-NVFP4",
      "gatewayModel": "unsloth/Qwen3.6-35B-A3B-NVFP4",
      "runtime": "unsloth-qwen36-35b-a3b-nvfp4",
      "backendConfig": "unsloth-qwen36-35b-a3b-nvfp4",
      "backend": "vLLM CUDA",
      "input": ["text"],
      "output": ["text"],
      "capabilities": [
        "chat",
        "responses",
        "anthropic-messages",
        "streaming",
        "usage",
        "tools",
        "reasoning",
        "mtp",
        "batching",
        "long-context",
        "moe"
      ],
      "settings": {
        "contextWindow": 262144,
        "maxOutputTokens": 32768,
        "maxActiveRequests": 4,
        "memoryGb": 64,
        "priority": 100,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 900000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "lloom-qwen36-35b-a3b-nvfp4",
          "healthUrl": "http://127.0.0.1:${port}/health",
          "bootstrap": {
            "adapter": "docker",
            "image": "vllm/vllm-openai:v0.24.0",
            "createArgs": [
              "--restart",
              "unless-stopped",
              "--gpus",
              "all",
              "--ipc",
              "host",
              "-p",
              "127.0.0.1:${port}:8000",
              "-e",
              "CUTE_DSL_ARCH=sm_121a",
              "-v",
              "lloom-huggingface-cache:/root/.cache/huggingface",
              "-v",
              "lloom-vllm-cache:/root/.cache/vllm"
            ],
            "command": [
              "${upstreamModel}",
              "--host",
              "0.0.0.0",
              "--port",
              "8000",
              "--tensor-parallel-size",
              "1",
              "--trust-remote-code",
              "--dtype",
              "bfloat16",
              "--kv-cache-dtype",
              "fp8",
              "--attention-backend",
              "flashinfer",
              "--gpu-memory-utilization",
              "0.4",
              "--max-model-len",
              "262144",
              "--max-num-seqs",
              "4",
              "--max-num-batched-tokens",
              "8192",
              "--enable-chunked-prefill",
              "--async-scheduling",
              "--enable-prefix-caching",
              "--load-format",
              "fastsafetensors",
              "--reasoning-parser",
              "qwen3",
              "--tool-call-parser",
              "qwen3_xml",
              "--enable-auto-tool-choice",
              "--speculative-config",
              "{\"method\":\"mtp\",\"num_speculative_tokens\":2}"
            ]
          }
        }
      }
    },
    {
      "role": "dense-quality",
      "model": "unsloth/Qwen3.6-27B-NVFP4",
      "gatewayModel": "unsloth/Qwen3.6-27B-NVFP4",
      "runtime": "unsloth-qwen36-27b-nvfp4",
      "backendConfig": "unsloth-qwen36-27b-nvfp4",
      "backend": "vLLM CUDA",
      "input": ["text"],
      "output": ["text"],
      "capabilities": [
        "chat",
        "responses",
        "anthropic-messages",
        "streaming",
        "usage",
        "tools",
        "reasoning",
        "mtp",
        "batching",
        "long-context"
      ],
      "settings": {
        "contextWindow": 262144,
        "maxOutputTokens": 32768,
        "maxActiveRequests": 8,
        "memoryGb": 64,
        "priority": 90,
        "evictable": true,
        "keepWarm": false,
        "startupTimeoutMs": 900000,
        "runtime": {
          "adapter": "docker",
          "management": "managed",
          "containerName": "lloom-qwen36-27b-nvfp4",
          "healthUrl": "http://127.0.0.1:${port}/health",
          "watchdog": {
            "enabled": true,
            "failureThreshold": 2,
            "failureWindowMs": 600000,
            "minNoProgressMs": 120000,
            "cooldownMs": 600000,
            "drainTimeoutMs": 30000
          },
          "bootstrap": {
            "adapter": "docker",
            "image": "vllm/vllm-openai:v0.25.0",
            "createArgs": [
              "--restart",
              "unless-stopped",
              "--gpus",
              "all",
              "--ipc",
              "host",
              "-p",
              "127.0.0.1:${port}:8000",
              "-e",
              "CUTE_DSL_ARCH=sm_121a",
              "-v",
              "lloom-huggingface-cache:/root/.cache/huggingface",
              "-v",
              "lloom-vllm-cache:/root/.cache/vllm"
            ],
            "command": [
              "${upstreamModel}",
              "--host",
              "0.0.0.0",
              "--port",
              "8000",
              "--tensor-parallel-size",
              "1",
              "--trust-remote-code",
              "--dtype",
              "bfloat16",
              "--kv-cache-dtype",
              "fp8",
              "--attention-backend",
              "flashinfer",
              "--gpu-memory-utilization",
              "0.4",
              "--max-model-len",
              "262144",
              "--max-num-seqs",
              "8",
              "--max-num-batched-tokens",
              "8192",
              "--enable-chunked-prefill",
              "--async-scheduling",
              "--enable-prefix-caching",
              "--load-format",
              "fastsafetensors",
              "--reasoning-parser",
              "qwen3",
              "--tool-call-parser",
              "qwen3_xml",
              "--enable-auto-tool-choice",
              "--speculative-config",
              "{\"method\":\"mtp\",\"num_speculative_tokens\":2}"
            ]
          }
        }
      }
    }
  ]
}
