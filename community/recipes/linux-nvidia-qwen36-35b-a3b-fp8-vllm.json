{
  "$schema": "https://lloom.dev/schemas/recipe.v1.schema.json",
  "schemaVersion": 1,
  "profile": "https://lloom.dev/profiles/interchange/v1",
  "id": "linux-nvidia-qwen36-35b-a3b-fp8-vllm",
  "name": "Linux NVIDIA Qwen3.6 35B-A3B FP8 vLLM",
  "version": 1,
  "summary": "CUDA/NVIDIA Qwen3.6 35B-A3B MoE lane using vLLM — primary DGX Spark / GB10 agent default for throughput + tools + long context.",
