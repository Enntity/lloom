          "action": "python-venv",
          "description": "Create a LLooM-managed Python environment for MTPLX.",
          "skipIfExecutableExists": ["${LLOOM_MTPLX_BIN}"],
          "path": "${installRoot}/mtplx/venv"
        },
        {
          "id": "install-mtplx",
          "title": "Install MTPLX package",
          "action": "pip-install",
          "description": "Install the published MTPLX package into the LLooM-managed environment.",
          "skipIfExecutableExists": ["${LLOOM_MTPLX_BIN}", "${installRoot}/mtplx/venv/bin/mtplx"],
          "venv": "${installRoot}/mtplx/venv",
