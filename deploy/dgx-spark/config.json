{
  "server": {
    "host": "0.0.0.0",
    "port": 8100
  },
  "security": {
    "allowMissingAuth": false,
    "allowRemoteAdmin": true,
    "allowWildcardCors": false,
    "allowNonLoopbackBind": true,
    "publicTelemetry": true,
    "apiKeys": ["${LLOOM_API_KEY}"],
    "adminApiKeys": ["${LLOOM_ADMIN_API_KEY}"]
  },
  "community": {
    "autoStartLocalHost": false
  },
  "defaults": {
    "chatModel": "unsloth/Qwen3.6-35B-A3B-NVFP4-Fast"
  },
  "runtimePolicy": {
    "enabled": true,
    "autoEvict": true,
    "maxMemoryUtilization": 0.9,
    "protectActiveRequests": true,
    "protectKeepWarm": false
  },
  "backends": {
    "spark-vllm-8000": {
      "baseUrl": "http://192.168.1.131:8000/v1",
      "timeoutMs": 1800000
    },
    "spark-vllm-8001": {
      "baseUrl": "http://192.168.1.131:8001/v1",
      "timeoutMs": 1800000
    }
  },
  "runtimes": {
    "qwen36-unsloth": {
      "enabled": true,
      "adapter": "docker",
      "management": "managed",
      "containerName": "qwen36-unsloth",
      "port": 8000,
      "healthUrl": "http://192.168.1.131:8000/v1/models",
      "maxConcurrency": 4,
      "memoryGb": 64,
      "keepWarm": true,
      "startupTimeoutMs": 600000,
      "policy": { "priority": 50, "evictable": true },
      "recipe": { "id": "dgx-spark-qwen36-nvfp4-mtp", "version": 1 },
      "bootstrap": {
        "adapter": "docker",
        "image": "vllm/vllm-openai:v0.24.0",
        "createArgs": ["--restart", "unless-stopped", "--gpus", "all", "--ipc", "host", "-p", "192.168.1.131:8000:8000", "-e", "CUTE_DSL_ARCH=sm_121a", "-v", "/home/enntitysparkadmin/.cache/huggingface:/root/.cache/huggingface", "-v", "/home/enntitysparkadmin/.cache/vllm:/root/.cache/vllm"],
        "command": ["unsloth/Qwen3.6-35B-A3B-NVFP4", "--host", "0.0.0.0", "--port", "8000", "--tensor-parallel-size", "1", "--trust-remote-code", "--dtype", "bfloat16", "--kv-cache-dtype", "fp8", "--attention-backend", "flashinfer", "--gpu-memory-utilization", "0.4", "--max-model-len", "262144", "--max-num-seqs", "4", "--max-num-batched-tokens", "8192", "--enable-chunked-prefill", "--async-scheduling", "--enable-prefix-caching", "--load-format", "fastsafetensors", "--reasoning-parser", "qwen3", "--tool-call-parser", "qwen3_xml", "--enable-auto-tool-choice", "--speculative-config", "{\"method\":\"mtp\",\"num_speculative_tokens\":2}"]
      }
    },
    "qwen36-unsloth-fast": {
      "enabled": true,
      "adapter": "docker",
      "management": "managed",
      "containerName": "qwen36-unsloth-fast",
      "port": 8001,
      "healthUrl": "http://192.168.1.131:8001/v1/models",
      "maxConcurrency": 4,
      "memoryGb": 64,
      "keepWarm": false,
      "startupTimeoutMs": 600000,
      "policy": { "priority": 100, "evictable": true },
      "recipe": { "id": "dgx-spark-qwen36-nvfp4-fast-mtp", "version": 1 },
      "bootstrap": {
        "adapter": "docker",
        "image": "vllm/vllm-openai:v0.24.0",
        "createArgs": ["--restart", "unless-stopped", "--gpus", "all", "--ipc", "host", "-p", "192.168.1.131:8001:8000", "-e", "CUTE_DSL_ARCH=sm_121a", "-v", "/home/enntitysparkadmin/.cache/huggingface:/root/.cache/huggingface", "-v", "/home/enntitysparkadmin/.cache/vllm:/root/.cache/vllm"],
        "command": ["unsloth/Qwen3.6-35B-A3B-NVFP4-Fast", "--host", "0.0.0.0", "--port", "8000", "--tensor-parallel-size", "1", "--trust-remote-code", "--dtype", "bfloat16", "--kv-cache-dtype", "fp8", "--attention-backend", "flashinfer", "--gpu-memory-utilization", "0.4", "--max-model-len", "262144", "--max-num-seqs", "4", "--max-num-batched-tokens", "8192", "--enable-chunked-prefill", "--async-scheduling", "--enable-prefix-caching", "--load-format", "fastsafetensors", "--reasoning-parser", "qwen3", "--tool-call-parser", "qwen3_xml", "--enable-auto-tool-choice", "--speculative-config", "{\"method\":\"mtp\",\"num_speculative_tokens\":2}"]
      }
    }
  },
  "models": [
    {
      "id": "unsloth/Qwen3.6-35B-A3B-NVFP4",
      "name": "Qwen 3.6 35B A3B NVFP4 on DGX Spark",
      "kind": "chat",
      "backend": "spark-vllm-8000",
      "runtime": "qwen36-unsloth",
      "upstreamModel": "unsloth/Qwen3.6-35B-A3B-NVFP4",
      "contextWindow": 262144,
      "maxPromptTokens": 255000,
      "capabilities": ["chat", "streaming", "usage", "tools", "reasoning", "long-context", "batching", "speculative-decoding"]
    },
    {
      "id": "unsloth/Qwen3.6-35B-A3B-NVFP4-Fast",
      "name": "Qwen 3.6 35B A3B NVFP4 Fast MTP on DGX Spark",
      "kind": "chat",
      "backend": "spark-vllm-8001",
      "runtime": "qwen36-unsloth-fast",
      "upstreamModel": "unsloth/Qwen3.6-35B-A3B-NVFP4-Fast",
      "contextWindow": 262144,
      "maxPromptTokens": 255000,
      "capabilities": ["chat", "streaming", "usage", "tools", "reasoning", "long-context", "batching", "speculative-decoding"]
    }
  ]
}
