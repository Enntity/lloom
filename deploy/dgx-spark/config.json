      "policy": { "priority": 85, "evictable": true },
      "recipe": {
        "id": "unsloth-hf-qwen36-27b-nvfp4-dgx-spark",
        "version": 1,
        "source": "https://huggingface.co/unsloth/Qwen3.6-27B-NVFP4"
