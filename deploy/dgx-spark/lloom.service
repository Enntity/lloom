[Unit]
Description=LLooM model gateway and runtime manager
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=%h/.config/lloom/env
Environment=NODE_ENV=production
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=%h/.local/bin/node %h/.local/lib/node_modules/lloom/bin/lloom.mjs serve --config %h/.lloom/config.json
Restart=on-failure
RestartSec=3
NoNewPrivileges=true
PrivateTmp=true

[Install]
WantedBy=default.target
