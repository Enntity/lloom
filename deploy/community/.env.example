# Domain and ACME account
COMMUNITY_DOMAIN=lloom.enntity.com
ACME_EMAIL=ops@example.com

# Use image digests, never mutable tags, in production.
CADDY_IMAGE=caddy@sha256:replace-with-reviewed-digest
LLOOM_COMMUNITY_IMAGE=ghcr.io/enntity/lloom-community@sha256:replace-with-release-digest

# Absolute host paths. Keep the private key outside the checkout, owned by root,
# and never put either value in GitHub Actions secrets or a committed .env file.
LLOOM_SIGNING_PRIVATE_KEY=/opt/lloom-community/secrets/lloom-community-2026-private.pem
LLOOM_SIGNING_PUBLIC_KEY=/opt/lloom-community/secrets/lloom-community-2026-public.pem
