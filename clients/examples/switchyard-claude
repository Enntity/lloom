#!/bin/sh
set -eu
switchyard_home="${SWITCHYARD_HOME:-$HOME/.switchyard}"
profile="$switchyard_home/integrations/claude.env"
if [ ! -f "$profile" ]; then
  echo "Switchyard profile missing: $profile" >&2
  echo "Run: switchyard integrate claude --apply --yes" >&2
  exit 1
fi
. "$profile"
exec "${SWITCHYARD_CLAUDE_BIN:-claude}" "$@"
